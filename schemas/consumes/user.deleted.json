{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "user.deleted",
  "description": "An account deletion was executed. stapel-tasks anonymizes the user's authored cards/comments and drops their assignments.",
  "type": "object",
  "required": ["user_id"],
  "properties": {
    "user_id":        { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "trigger":        { "type": "string", "enum": ["manual", "inactivity", "platform"] },
    "deleted_at":     { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
